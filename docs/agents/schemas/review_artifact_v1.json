{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "review_artifact_v1",
  "title": "Review Artifact v1",
  "description": "Output of the Critic agent. The release gate. Critic is the ONLY agent that produces this artifact. Must verify staging behavior, not just code.",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "trace_id", "agent", "kind", "artifact_id", "micro_spec_id", "spec_verdict", "security_verdict", "findings", "ship_recommendation", "parent_artifact_ids", "started_at", "finished_at", "status"],
  "properties": {
    "schema_version": { "type": "string", "const": "1.0" },
    "trace_id": { "type": "string" },
    "agent": { "type": "string", "const": "critic" },
    "kind": { "type": "string", "const": "review_artifact_v1" },
    "artifact_id": { "type": "string" },
    "micro_spec_id": { "type": "string" },
    "spec_verdict": { "type": "string", "enum": ["pass", "fail"], "description": "Did the staging behavior satisfy all acceptance criteria?" },
    "security_verdict": { "type": "string", "enum": ["pass", "fail"], "description": "Are there security issues that block release?" },
    "findings": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["severity", "owner", "description"],
        "properties": {
          "severity": { "type": "string", "enum": ["low", "medium", "high"] },
          "owner": { "type": "string", "enum": ["frontend", "backend", "platform", "planner"] },
          "description": { "type": "string" }
        }
      },
      "description": "If any finding has severity=high, ship_recommendation MUST be reject"
    },
    "ship_recommendation": { "type": "string", "enum": ["approve", "reject"] },
    "parent_artifact_ids": { "type": "array", "items": { "type": "string" } },
    "started_at": { "type": "string", "format": "date-time" },
    "finished_at": { "type": "string", "format": "date-time" },
    "status": { "type": "string", "enum": ["approve", "reject", "needs_clarification"] },
    "reason": { "type": "string" }
  },
  "examples": [
    {
      "schema_version": "1.0",
      "trace_id": "trc_101",
      "agent": "critic",
      "kind": "review_artifact_v1",
      "artifact_id": "art_rev_101",
      "micro_spec_id": "ms_101",
      "spec_verdict": "pass",
      "security_verdict": "pass",
      "findings": [],
      "ship_recommendation": "approve",
      "parent_artifact_ids": ["ms_101", "art_fe_101", "art_dep_101"],
      "started_at": "2026-04-13T09:10:00-07:00",
      "finished_at": "2026-04-13T09:16:00-07:00",
      "status": "approve",
      "reason": "Acceptance criteria met and no security issues found"
    }
  ]
}
