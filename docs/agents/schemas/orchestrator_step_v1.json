{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "orchestrator_step_v1",
  "title": "Orchestrator Step v1",
  "description": "Output of the Orchestrator agent at each step. Controls routing only. Never contains product decisions.",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "trace_id", "agent", "kind", "step_id", "workflow_mode", "next_step", "required_inputs", "parent_artifact_ids", "owner_micro_spec_id", "started_at", "finished_at", "status"],
  "properties": {
    "schema_version": { "type": "string", "const": "1.0" },
    "trace_id": { "type": "string" },
    "agent": { "type": "string", "const": "orchestrator" },
    "kind": { "type": "string", "const": "orchestrator_step_v1" },
    "step_id": { "type": "string" },
    "workflow_mode": { "type": "string", "enum": ["core", "extended"] },
    "next_step": { "type": "string", "enum": ["plan", "build_frontend", "build_backend", "platform", "critic", "done", "human_escalation"] },
    "required_inputs": { "type": "array", "items": { "type": "string" } },
    "parent_artifact_ids": { "type": "array", "items": { "type": "string" } },
    "owner_micro_spec_id": { "type": "string" },
    "started_at": { "type": "string", "format": "date-time" },
    "finished_at": { "type": "string", "format": "date-time" },
    "status": { "type": "string", "enum": ["ok", "blocked", "needs_clarification"] },
    "reason": { "type": "string" }
  },
  "examples": [
    {
      "schema_version": "1.0",
      "trace_id": "trc_101",
      "agent": "orchestrator",
      "kind": "orchestrator_step_v1",
      "step_id": "step_2",
      "workflow_mode": "core",
      "next_step": "build_frontend",
      "required_inputs": ["micro_spec_v1"],
      "parent_artifact_ids": ["art_ms_101"],
      "owner_micro_spec_id": "ms_101",
      "started_at": "2026-04-13T08:58:00-07:00",
      "finished_at": "2026-04-13T08:58:01-07:00",
      "status": "ok",
      "reason": "UI-only change routed to frontend builder"
    }
  ]
}
